# Copy this file to `.env` and fill in real values.
# DATABRICKS_HOST: your workspace URL, e.g. https://adb-1234567890.12.azuredatabricks.net
# DATABRICKS_TOKEN: a personal access token (PAT). Create one under
#   User Settings -> Developer -> Access tokens in the Databricks UI.
DATABRICKS_HOST=
DATABRICKS_TOKEN=
